{
  "version": 2,
  "functions": {
    "api/*.js": {
      "includeFiles": "{index.html,product_detail.html}"
    }
  },
  "routes": [
    {
      "src": "/product/(?<slug>[a-zA-Z0-9_-]+)",
      "dest": "/api/index.js?slug=$slug"
    },
    {
      "src": "/",
      "dest": "/api/home.js"
    },
    {
      "src": "/api/checkout",
      "dest": "/api/checkout.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/storage/(.*)",
      "dest": "/storage/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/home.js"
    }
  ]
}
